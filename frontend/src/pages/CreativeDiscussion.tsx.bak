/*创意讨论页面 - 使用协调Agent工作流*/
import { useState, useEffect, useRef } from 'react';
import { Send, CheckCircle } from '@geist-ui/icons';
import { useNavigate, useSearchParams } from 'react-router-dom';
import { coordinatorService } from '../services/coordinatorService';
import { sessionService } from '../services/sessionService';
import { projectService } from '../services/projectService';
import type { Project, WorkflowState, Message } from '../types';
import './CreativeDiscussion.css';

// 简单的加载图标组件
const LoadingIcon = () => (
  <svg className="loading-icon" viewBox="0 0 50 50" style={{width: 24, height: 24}}>
    <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" strokeWidth="5">
      <animate attributeName="stroke-dasharray" from="0, 100" to="100, 0" dur="2s" repeatCount="indefinite"/>
      <animate attributeName="stroke-dashoffset" from="0" to="-100" dur="2s" repeatCount="indefinite"/>
    </circle>
  </svg>
);

export default function CreativeDiscussion() {
  const [input, setInput] = useState('');
  const messagesEndRef = useRef<HTMLDivElement>(null);
  const inputRef = useRef<HTMLTextAreaElement>(null);
  const [searchParams] = useSearchParams();
  const navigate = useNavigate();
  const [currentProject, setCurrentProject] = useState<Project | null>(null);
  const [isInitializing, setIsInitializing] = useState(true);
  const [workflowState, setWorkflowState] = useState<WorkflowState>({ current_step: 'input' });
  const [messages, setMessages] = useState<Message[]>([]);
  const [sessionId, setSessionId] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(false);
  const [suggestions, setSuggestions] = useState<string[]>([]);

  // 自动滚动到底部
  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  };

  // 初始化会话
  useEffect(() => {
    const initializeSession = async () => {
      const projectId = searchParams.get('projectId');

      if (projectId) {
        try {
          // 加载项目信息
          const project = await projectService.get(projectId);
          setCurrentProject(project);

          // 尝试加载工作流状态
          try {
            const workflowData = await coordinatorService.getWorkflowState(projectId);
            if (workflowData.workflow_state) {
              setWorkflowState(workflowData.workflow_state);
            }
          } catch (e) {
            // 如果没有工作流状态，使用默认值
            console.log('没有找到工作流状态');
          }

          // 查找或创建会话
          const sessions = await sessionService.getProjectSessions(projectId, 'coordinator');
          if (sessions.length > 0) {
            // 加载现有会话
            const session = sessions[0];
            setSessionId(session.id);
            setMessages(session.messages);
            if (session.context?.suggestions) {
              setSuggestions(session.context.suggestions);
            }
          } else {
            // 创建新会话
            const newSession = await sessionService.create({
              project_id: projectId,
              agent_type: 'coordinator',
            });
            setSessionId(newSession.id);
            setMessages([]);

            // 获取初始建议
            try {
              const initialSuggestions = await coordinatorService.chat({
                message: '',
                project_id: projectId,
                session_id: newSession.id,
                workflow_state: { current_step: 'input' },
              });
              if (initialSuggestions.suggestions) {
                setSuggestions(initialSuggestions.suggestions);
              }
            } catch (e) {
              // 如果获取建议失败，使用默认建议
              console.log('获取建议失败，使用默认建议');
            }
          }
        } catch (error) {
          console.error('初始化会话失败:', error);
        }
      } else {
        // 没有项目ID，清空状态
        setCurrentProject(null);
        setMessages([]);
        setWorkflowState({ current_step: 'input' });
        setSuggestions([]);
      }
      setIsInitializing(false);
    };

    initializeSession();
  }, [searchParams.get('projectId')]);

  useEffect(() => {
    scrollToBottom();
  }, [messages]);

  // 添加消息
  const addMessage = (message: Message) => {
    setMessages((prev) => [...prev, message]);
  };

  // 保存消息到会话
  const saveMessages = async (messagesToAdd: Message[], context?: Record<string, any>) => {
    if (!sessionId || !currentProject) return;

    try {
      await sessionService.appendMessages(sessionId, messagesToAdd, context);
    } catch (error) {
      console.error('保存消息失败:', error);
    }
  };

  // 保存工作流状态
  const saveWorkflowState = async (newState: WorkflowState) => {
    if (!currentProject) return;

    try {
      await coordinatorService.saveWorkflowState(currentProject.id, newState);
      setWorkflowState(newState);
    } catch (error) {
      console.error('保存工作流状态失败:', error);
    }
  };

  // 处理发送消息
  const handleSend = async () => {
    if (!input.trim() || isLoading || !currentProject) return;

    const userMessage = input.trim();
    setInput('');

    const userMsgObj: Message = {
      role: 'user',
      content: userMessage,
      timestamp: new Date().toISOString(),
    };

    // 添加用户消息
    addMessage(userMsgObj);

    setIsLoading(true);

    try {
      // 调用协调Agent
      const response = await coordinatorService.chat({
        message: userMessage,
        project_id: currentProject.id,
        session_id: sessionId || undefined,
        workflow_state: workflowState,
      });

      const assistantMsgObj: Message = {
        role: 'assistant',
        content: response.message,
        timestamp: new Date().toISOString(),
      };

      // 添加AI回复
      addMessage(assistantMsgObj);

      // 立即更新工作流状态和建议（不需要等待保存）
      setWorkflowState(response.workflow_state);
      setSuggestions(response.suggestions);

      // 保存消息到会话
      await saveMessages([userMsgObj, assistantMsgObj], {
        suggestions: response.suggestions,
        workflow_state: response.workflow_state,
      });

      // 异步保存工作流状态到后端
      saveWorkflowState(response.workflow_state);
    } catch (error) {
      console.error('发送消息失败:', error);
      const errorMsgObj: Message = {
        role: 'assistant',
        content: '抱歉，我遇到了一些问题。请稍后再试。',
        timestamp: new Date().toISOString(),
      };
      addMessage(errorMsgObj);
      await saveMessages([userMsgObj, errorMsgObj]);
    } finally {
      setIsLoading(false);
    }
  };

  // 处理快捷建议点击
  const handleSuggestionClick = (suggestion: string) => {
    setInput(suggestion);
  };

  // 获取步骤名称
  const getStepName = (step: string) => {
    const stepNames: Record<string, string> = {
      input: '输入创意',
      planning: '制定计划',
      storyboard_prompts: '分镜提示词',
      generating_storyboard: '生成分镜',
      video_prompts: '视频提示词',
      generating_video: '生成视频',
      completed: '完成',
    };
    return stepNames[step] || step;
  };

  // 工作流步骤指示器
  const WorkflowIndicator = () => {
    const steps: WorkflowState['current_step'][] = [
      'input',
      'planning',
      'storyboard_prompts',
      'generating_storyboard',
      'video_prompts',
      'generating_video',
      'completed',
    ];

    const currentStepIndex = steps.indexOf(workflowState.current_step);

    // 调试日志
    console.log('=== 工作流状态 ===');
    console.log('当前步骤:', workflowState.current_step);
    console.log('步骤索引:', currentStepIndex);
    console.log('计划对象:', workflowState.plan);
    console.log('分镜提示词数量:', workflowState.plan?.storyboard_prompts?.length || 0);
    if (workflowState.plan?.storyboard_prompts) {
      console.log('第一个提示词:', workflowState.plan.storyboard_prompts[0]?.substring(0, 100));
    }

    return (
      <div className="workflow-indicator">
        {steps.map((step, index) => {
          const isCompleted = index < currentStepIndex;
          const isCurrent = index === currentStepIndex;
          const isPending = index > currentStepIndex;

          return (
            <div key={step} className="workflow-step">
              <div className={`step-dot ${isCompleted ? 'completed' : ''} ${isCurrent ? 'current' : ''} ${isPending ? 'pending' : ''}`}>
                {isCompleted ? <CheckCircle /> : index + 1}
              </div>
              <div className={`step-label ${isCurrent ? 'current' : ''}`}>
                {getStepName(step)}
              </div>
              {index < steps.length - 1 && <div className="step-line" />}
            </div>
          );
        })}
      </div>
    );
  };

  if (isInitializing) {
    return (
      <div className="creative-discussion">
        <div className="loading-state">
          <LoadingIcon />
          <p>加载中...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="creative-discussion">
      <div className="discussion-header">
        <div className="header-title">
          <h1>💭 创意讨论</h1>
          {currentProject ? (
            <div className="project-badge">
              <span className="project-label">项目:</span>
              <span className="project-name">{currentProject.title}</span>
            </div>
          ) : (
            <div className="no-project-warning">
              <p>⚠️ 未选择项目</p>
              <button
                className="btn-link"
                onClick={() => navigate('/projects')}
              >
                去选择或创建项目 →
              </button>
            </div>
          )}
        </div>
        {currentProject && (
          <>
            <p className="header-description">与AI助手讨论你的视频创意</p>
            <WorkflowIndicator />
          </>
        )}
      </div>

      <div className="messages-container">
        {messages.length === 0 ? (
          <div className="empty-state">
            <div className="empty-icon">💬</div>
            <h3>开始创作你的视频</h3>
            <p>告诉我你想要制作什么样的视频，我会帮你规划整个创作流程</p>
            <div className="empty-suggestions">
              <p style={{marginBottom: '12px', color: '#666'}}>试试这些创意：</p>
              {suggestions.length > 0 ? suggestions.map((suggestion, index) => (
                <button
                  key={index}
                  className="suggestion-button"
                  onClick={() => handleSuggestionClick(suggestion)}
                >
                  {suggestion}
                </button>
              )) : [
                '🌸 制作一个春天的主题短片',
                '🎬 创作一个产品宣传视频',
                '📱 制作一个APP使用教程',
                '🎨 创作一个艺术展示视频'
              ].map((suggestion, index) => (
                <button
                  key={index}
                  className="suggestion-button"
                  onClick={() => handleSuggestionClick(suggestion)}
                >
                  {suggestion}
                </button>
              ))}
            </div>
          </div>
        ) : (
          <>
            {messages.map((msg, index) => (
              <div
                key={index}
                className={`message ${msg.role === 'user' ? 'user-message' : 'assistant-message'}`}
              >
                <div className="message-content">
                  <div className="message-avatar">
                    {msg.role === 'user' ? '👤' : '🤖'}
                  </div>
                  <div className="message-bubble">
                    <div className="message-text">{msg.content}</div>
                    <div className="message-time">
                      {msg.timestamp && new Date(msg.timestamp).toLocaleTimeString()}
                    </div>
                  </div>
                </div>
              </div>
            ))}
            {isLoading && (
              <div className="message assistant-message">
                <div className="message-content">
                  <div className="message-avatar">🤖</div>
                  <div className="message-bubble loading">
                    <LoadingIcon />
                  </div>
                </div>
              </div>
            )}
            <div ref={messagesEndRef} />
          </>
        )}
      </div>

      {/* 显示分镜提示词卡片 */}
      {workflowState.current_step === 'storyboard_prompts' && workflowState.plan?.storyboard_prompts && workflowState.plan.storyboard_prompts.length > 0 && (
        <div className="storyboard-prompts-cards">
          <h3>📸 分镜提示词</h3>
          <p className="cards-description">点击卡片前往分镜工作台生成图片（每个场景将生成 2 张）</p>
          <div className="prompts-grid">
            {workflowState.plan.storyboard_prompts.map((prompt, index) => {
              // 提取场景标题
              const titleMatch = prompt.match(/📸\s*分镜\s*#(\d+)[:：]\s*([^\n]+)/);
              const title = titleMatch ? titleMatch[2].trim() : `分镜 #${index + 1}`;

              // 提取场景描述
              const descMatch = prompt.match(/场景描述[:：]\s*([^\n]+)/);
              const description = descMatch ? descMatch[1].trim() : prompt.substring(0, 100);

              return (
                <div
                  key={index}
                  className="prompt-card"
                  onClick={() => {
                    // 调试日志
                    console.log('=== 点击卡片 ===');
                    console.log('点击索引:', index);
                    console.log('项目ID:', currentProject?.id);
                    console.log('提示词:', prompt.substring(0, 100));

                    // 编码提示词以便传递
                    const encodedPrompt = encodeURIComponent(prompt);
                    const targetUrl = `/storyboard?projectId=${currentProject?.id}&promptIndex=${index}&useCoordinator=true`;
                    console.log('目标URL:', targetUrl);

                    navigate(targetUrl);
                  }}
                >
                  <div className="prompt-card-header">
                    <span className="prompt-number">分镜 #{index + 1}</span>
                    <span className="prompt-action">→ 前往生图</span>
                  </div>
                  <div className="prompt-card-title">{title}</div>
                  <div className="prompt-card-desc">{description}</div>
                  <div className="prompt-card-meta">
                    <span className="meta-tag">默认生成2张</span>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* 显示生成的分镜图片 */}
      {workflowState.storyboard_images && workflowState.storyboard_images.length > 0 && (
        <div className="storyboard-images">
          <h3>📸 生成的分镜图片</h3>
          <div className="images-grid">
            {workflowState.storyboard_images.map((imageUrl, index) => (
              <div key={index} className="image-card">
                <img src={imageUrl} alt={`分镜 ${index + 1}`} />
                <div className="image-actions">
                  <button className="btn btn-secondary" onClick={() => window.open(imageUrl, '_blank')}>
                    查看大图
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* 建议操作 */}
      {suggestions.length > 0 && !isLoading && messages.length > 0 && (
        <div className="suggestions">
          {suggestions.map((suggestion, index) => (
            <button
              key={index}
              className="suggestion-button"
              onClick={() => handleSuggestionClick(suggestion)}
            >
              {suggestion}
            </button>
          ))}
        </div>
      )}

      {/* 根据工作流状态显示不同的操作按钮 */}
      {/* 计划确认阶段的操作按钮 */}
      {workflowState.current_step === 'planning' && !isLoading && (
        <div className="quick-actions">
          <button
            className="action-button primary"
            onClick={async () => {
              const message = '确认';
              const userMsg: Message = {
                role: 'user',
                content: message,
                timestamp: new Date().toISOString(),
              };
              addMessage(userMsg);
              setInput('');
              setIsLoading(true);
              try {
                const response = await coordinatorService.chat({
                  message,
                  project_id: currentProject!.id,
                  session_id: sessionId || undefined,
                  workflow_state: workflowState,
                });
                addMessage({
                  role: 'assistant',
                  content: response.message,
                  timestamp: new Date().toISOString(),
                });
                setWorkflowState(response.workflow_state);
                setSuggestions(response.suggestions);
                saveWorkflowState(response.workflow_state);
              } catch (err) {
                console.error('发送失败:', err);
                addMessage({
                  role: 'assistant',
                  content: '抱歉，操作失败。请重试。',
                  timestamp: new Date().toISOString(),
                });
              } finally {
                setIsLoading(false);
              }
            }}
          >
            ✅ 确认计划并继续
          </button>
          <button
            className="action-button secondary"
            onClick={() => {
              setInput('请修改一下计划，我想要：');
              setTimeout(() => inputRef.current?.focus(), 100);
            }}
          >
            🔄 修改计划
          </button>
          <button
            className="action-button secondary"
            onClick={async () => {
              const message = '重新生成计划';
              const userMsg: Message = {
                role: 'user',
                content: message,
                timestamp: new Date().toISOString(),
              };
              addMessage(userMsg);
              setInput('');
              setIsLoading(true);
              try {
                const response = await coordinatorService.chat({
                  message,
                  project_id: currentProject!.id,
                  session_id: sessionId || undefined,
                  workflow_state: workflowState,
                });
                addMessage({
                  role: 'assistant',
                  content: response.message,
                  timestamp: new Date().toISOString(),
                });
                setWorkflowState(response.workflow_state);
                setSuggestions(response.suggestions);
                saveWorkflowState(response.workflow_state);
              } catch (err) {
                console.error('发送失败:', err);
                addMessage({
                  role: 'assistant',
                  content: '抱歉，操作失败。请重试。',
                  timestamp: new Date().toISOString(),
                });
              } finally {
                setIsLoading(false);
              }
            }}
          >
            🔃 重新生成
          </button>
        </div>
      )}

      {/* 分镜提示词确认阶段的操作按钮 */}
      {workflowState.current_step === 'storyboard_prompts' && !isLoading && (
        <div className="quick-actions">
          <button
            className="action-button primary"
            onClick={async () => {
              const message = '确认';
              const userMsg: Message = {
                role: 'user',
                content: message,
                timestamp: new Date().toISOString(),
              };
              addMessage(userMsg);
              setInput('');
              setIsLoading(true);
              try {
                const response = await coordinatorService.chat({
                  message,
                  project_id: currentProject!.id,
                  session_id: sessionId || undefined,
                  workflow_state: workflowState,
                });
                addMessage({
                  role: 'assistant',
                  content: response.message,
                  timestamp: new Date().toISOString(),
                });
                setWorkflowState(response.workflow_state);
                setSuggestions(response.suggestions);
                saveWorkflowState(response.workflow_state);
              } catch (err) {
                console.error('发送失败:', err);
                addMessage({
                  role: 'assistant',
                  content: '抱歉，操作失败。请重试。',
                  timestamp: new Date().toISOString(),
                });
              } finally {
                setIsLoading(false);
              }
            }}
          >
            ✅ 确认提示词并生成图片
          </button>
          <button
            className="action-button secondary"
            onClick={() => {
              setInput('请修改分镜提示词，我想要：');
              setTimeout(() => inputRef.current?.focus(), 100);
            }}
          >
            🔄 需要修改
          </button>
          <button
            className="action-button secondary"
            onClick={async () => {
              const message = '重新生成分镜提示词';
              const userMsg: Message = {
                role: 'user',
                content: message,
                timestamp: new Date().toISOString(),
              };
              addMessage(userMsg);
              setInput('');
              setIsLoading(true);
              try {
                const response = await coordinatorService.chat({
                  message,
                  project_id: currentProject!.id,
                  session_id: sessionId || undefined,
                  workflow_state: workflowState,
                });
                addMessage({
                  role: 'assistant',
                  content: response.message,
                  timestamp: new Date().toISOString(),
                });
                setWorkflowState(response.workflow_state);
                setSuggestions(response.suggestions);
                saveWorkflowState(response.workflow_state);
              } catch (err) {
                console.error('发送失败:', err);
                addMessage({
                  role: 'assistant',
                  content: '抱歉，操作失败。请重试。',
                  timestamp: new Date().toISOString(),
                });
              } finally {
                setIsLoading(false);
              }
            }}
          >
            🔃 重新生成
          </button>
        </div>
      )}

      {workflowState.current_step === 'generating_storyboard' && !isLoading && (
        <div className="quick-actions">
          {workflowState.storyboard_images && workflowState.storyboard_images.length > 0 ? (
            <>
              <button
                className="action-button"
                onClick={() => setInput('生成视频提示词')}
              >
                🎬 继续生成视频提示词
              </button>
              <button
                className="action-button"
                onClick={() => navigate('/storyboard?projectId=' + currentProject?.id)}
              >
                📸 分镜工作台
              </button>
            </>
          ) : (
            <button
              className="action-button"
              onClick={() => navigate('/storyboard?projectId=' + currentProject?.id)}
            >
              📸 前往分镜工作台生成图片
            </button>
          )}
        </div>
      )}

      {/* 输入区域 */}
      <div className="input-area">
        <div className="input-container">
          <textarea
            ref={inputRef}
            className="message-input"
            placeholder="输入你的想法..."
            value={input}
            onChange={(e) => setInput(e.target.value)}
            onKeyDown={(e) => {
              if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                handleSend();
              }
            }}
            rows={1}
          />
          <button
            className="send-button"
            onClick={handleSend}
            disabled={!input.trim() || isLoading || !currentProject}
          >
            <Send />
          </button>
        </div>
      </div>
    </div>
  );
}

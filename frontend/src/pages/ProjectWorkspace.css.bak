/*项目工作台样式 - V2深色主题*/
.project-workspace {
  display: flex;
  height: 100vh;
  background-color: var(--color-bg-primary);
  color: var(--color-text-primary);
  overflow: hidden;
}

.project-workspace-loading,
.project-workspace-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background-color: var(--color-bg-primary);
  color: var(--color-text-primary);
  gap: 16px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--color-bg-tertiary);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.project-workspace-empty h2 {
  margin: 0;
  font-size: var(--font-size-2xl);
  font-weight: 600;
}

.project-workspace-empty button {
  padding: 10px 20px;
  background: linear-gradient(135deg, var(--color-primary) 0%, #5B6CE6 100%);
  color: var(--color-text-inverse);
  border: none;
  border-radius: var(--radius-md);
  cursor: pointer;
  font-size: var(--font-size-base);
  font-weight: 500;
  transition: all var(--transition-base);
  box-shadow: var(--shadow-md);
}

.project-workspace-empty button:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-1px);
}

/* Canvas容器 */
.canvas-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg-primary);
  position: relative;
}

.canvas-header {
  padding: 20px 24px;
  background-color: var(--color-bg-secondary);
  border-bottom: 1px solid var(--color-border-default);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.canvas-title h1 {
  margin: 0 0 8px 0;
  font-size: var(--font-size-2xl);
  font-weight: 600;
  color: var(--color-text-primary);
}

.project-description {
  margin: 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.config-button {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-tertiary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-md);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition-base);
}

.config-button:hover {
  background: var(--color-bg-elevated);
  border-color: var(--color-primary);
  color: var(--color-primary);
}

/* React Flow样式覆盖 */
.react-flow {
  background-color: var(--color-bg-primary) !important;
}

.react-flow__edge-path {
  stroke: var(--color-border-default) !important;
  stroke-width: 2 !important;
}

.react-flow__edge.selected .react-flow__edge-path,
.react-flow__edge:hover .react-flow__edge-path {
  stroke: var(--color-primary) !important;
}

.react-flow__controls {
  background-color: var(--color-bg-secondary) !important;
  border: 1px solid var(--color-border-default) !important;
  box-shadow: var(--shadow-lg) !important;
}

.react-flow__controls-button {
  background-color: var(--color-bg-tertiary) !important;
  border-bottom: 1px solid var(--color-border-default) !important;
  fill: var(--color-text-secondary) !important;
}

.react-flow__controls-button:hover {
  background-color: var(--color-bg-elevated) !important;
  fill: var(--color-text-primary) !important;
}

.react-flow__minimap {
  background-color: var(--color-bg-secondary) !important;
  border: 1px solid var(--color-border-default) !important;
}

.react-flow__minimap-mask {
  fill: var(--color-primary) !important;
  fill-opacity: 0.1 !important;
}

.react-flow__background {
  background-color: var(--color-bg-primary) !important;
}

/* 响应式 */
@media (max-width: 768px) {
  .project-workspace {
    flex-direction: column;
  }

  .canvas-header {
    padding: 16px;
  }

  .canvas-header h1 {
    font-size: var(--font-size-xl);
  }
}
